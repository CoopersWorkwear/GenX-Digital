# ---------------------------------------------------------------------------
# GenX Digital — environment configuration
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local`. Secrets without the NEXT_PUBLIC_ prefix stay
# server-side only and are never shipped to the browser.
# ---------------------------------------------------------------------------

# --- Dreamscape Reseller API (server-side only) ----------------------------
# Find your API key in: Reseller Console > Account Settings > API & WHMCS > API Setup
# The key is 32 lowercase alphanumeric characters.
DREAMSCAPE_API_KEY=

# Environment: "sandbox" (default, safe for testing) or "production" (real money/domains).
# Sandbox credentials are the same as production; only the base URL differs.
DREAMSCAPE_ENV=sandbox

# Optional override of the base URL. Leave blank to derive it from DREAMSCAPE_ENV.
#   sandbox    -> https://reseller-api.sandbox.ds.network
#   production -> https://reseller-api.ds.network
DREAMSCAPE_BASE_URL=

# --- Pricing -----------------------------------------------------------------
# Default markup applied to Dreamscape cost prices (percentage). Per-product
# overrides live in the database. e.g. 25 = sell at cost + 25%.
DEFAULT_MARKUP_PERCENT=25

# --- Supabase (added in the accounts/checkout phase) ------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Payments (added in the payments phase) ---------------------------------
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Site --------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
