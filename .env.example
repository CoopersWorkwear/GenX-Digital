# ---------------------------------------------------------------------------
# GenX Digital — environment configuration
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local`. Secrets without the NEXT_PUBLIC_ prefix stay
# server-side only and are never shipped to the browser.
# ---------------------------------------------------------------------------

# --- Dreamscape Reseller API (server-side only) ----------------------------
# Find your API key in: Reseller Console > Account Settings > API & WHMCS > API Setup
# The key is 32 lowercase alphanumeric characters.
DREAMSCAPE_API_KEY=

# Environment: "sandbox" (default, safe for testing) or "production" (real money/domains).
# Sandbox credentials are the same as production; only the base URL differs.
DREAMSCAPE_ENV=sandbox

# Optional override of the base URL. Leave blank to derive it from DREAMSCAPE_ENV.
#   sandbox    -> https://reseller-api.sandbox.ds.network
#   production -> https://reseller-api.ds.network
DREAMSCAPE_BASE_URL=

# --- Pricing -----------------------------------------------------------------
# Default markup applied to Dreamscape cost prices (percentage). Per-product
# overrides live in the database. e.g. 25 = sell at cost + 25%.
DEFAULT_MARKUP_PERCENT=25

# --- Supabase (added in the accounts/checkout phase) ------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- AI asset generation (optional) -----------------------------------------
# Powers the website builder's "create a logo / images for me" options.
# Any OpenAI-compatible images API works — set the key (and base URL/model if
# using a different provider). Leave blank to capture requests for manual
# fulfilment instead of generating automatically.
AI_IMAGE_API_KEY=
AI_IMAGE_BASE_URL=https://api.openai.com/v1
AI_IMAGE_MODEL=gpt-image-1

# --- AI website generation (Claude) -----------------------------------------
# The website builder uses the Claude API to generate tailored site copy into
# the template. Get a key at console.anthropic.com. No per-site credits — billed
# as normal pay-as-you-go API usage. Leave blank to fall back to a basic
# template generated from the customer's description.
ANTHROPIC_API_KEY=

# --- Payments / saved cards (Stripe) ----------------------------------------
# Enables securely storing customer cards (tokenised by Stripe — raw card
# numbers never touch our servers). Get keys at dashboard.stripe.com (test mode
# first). Leave blank to keep the "card payments coming soon" state.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Webhook signing secret (Stripe Dashboard → Developers → Webhooks). Point the
# endpoint at /api/payments/webhook.
STRIPE_WEBHOOK_SECRET=

# --- Email (Resend) ----------------------------------------------------------
# Sends order confirmations and website-builder preview links. Get a key at
# resend.com; EMAIL_FROM must be a verified sender, e.g.
# "GenX Digital <noreply@genxdigital.com.au>". No-ops until set.
RESEND_API_KEY=
EMAIL_FROM=

# --- Admin -------------------------------------------------------------------
# Comma-separated emails allowed to view /admin (defaults to the business owner).
ADMIN_EMAILS=

# --- Site --------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
